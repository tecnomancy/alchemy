{
  "name": "fp-core",
  "version": "0.1.0",
  "description": "Functional programming primitives for TypeScript — Result, Option, pipe, compose, async utilities. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js"
    },
    "./option": {
      "types": "./dist/option.d.ts",
      "import": "./dist/option.js"
    },
    "./async": {
      "types": "./dist/async.d.ts",
      "import": "./dist/async.js"
    },
    "./array": {
      "types": "./dist/array.d.ts",
      "import": "./dist/array.js"
    },
    "./object": {
      "types": "./dist/object.d.ts",
      "import": "./dist/object.js"
    },
    "./string": {
      "types": "./dist/string.d.ts",
      "import": "./dist/string.js"
    },
    "./predicates": {
      "types": "./dist/predicates.d.ts",
      "import": "./dist/predicates.js"
    },
    "./composition": {
      "types": "./dist/composition.d.ts",
      "import": "./dist/composition.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepare": "husky"
  },
  "keywords": [
    "functional",
    "fp",
    "result",
    "either",
    "option",
    "maybe",
    "pipe",
    "compose",
    "curry",
    "typescript",
    "monad",
    "zero-dependency"
  ],
  "author": "roxdavirox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/roxdavirox/fp-core.git"
  },
  "bugs": {
    "url": "https://github.com/roxdavirox/fp-core/issues"
  },
  "homepage": "https://github.com/roxdavirox/fp-core#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  }
}
